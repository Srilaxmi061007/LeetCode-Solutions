class Solution:
    def largestRectangleArea(self, heights: List[int]) -> int:
        st = []
        max_area = 0
        for i, h in enumerate(heights):
            idx = i
            while st and st[-1][1] > h:
                idx, prev_h = st.pop()
                max_area = max(max_area, prev_h * (i - idx))
            st.append((idx, h))
        n = len(heights)
        while st:
            idx, h = st.pop()
            max_area = max(max_area, h * (n - idx))
        return max_area
